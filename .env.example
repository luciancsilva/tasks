# =============================================================================
# tududi — exemplo de .env
# Copie para .env (na raiz do repositório) e preencha. O .env é gitignored;
# nunca commite segredos. docker-compose.yml interpola estas variáveis.
# =============================================================================

# ===== tududi =====
# Porta exposta pelo docker-compose (mapeada para 3002 do container).
TUDUDI_PORT=3002
# Usuário admin criado automaticamente no primeiro boot.
TUDUDI_USER_EMAIL=admin@exemplo.com.br
TUDUDI_USER_PASSWORD=troque-esta-senha
# Gere com: openssl rand -hex 64
TUDUDI_SESSION_SECRET=troque-use-openssl-rand-hex-64
TUDUDI_ALLOWED_ORIGINS=http://localhost:3002
# false, 1 (um proxy reverso na frente) ou número de hops.
TUDUDI_TRUST_PROXY=false
TZ=America/Sao_Paulo

# ===== Cloudflare (conta compartilhada entre R2 e D1) =====
# Painel Cloudflare → qualquer página da conta → Account ID na barra lateral
# direita (ou na URL do dash).
CLOUDFLARE_ACCOUNT_ID=

# ===== Cloudflare R2 (storage de anexos/avatares/capas/branding) =====
# Opcional: sem estas variáveis o app sobe, mas uploads falham até configurar.
#
# COMO OBTER:
#   1. Painel → R2 → criar bucket (anote o nome exato).
#   2. Painel → R2 → "Manage R2 API Tokens" → Create API Token:
#        - Permissão: "Object Read & Write"
#        - Escopo: "Apply to specific buckets" → selecione o bucket acima
#        - (equivalente via Account API Tokens: policy "Workers R2 Storage
#          Bucket Item" com Read + Edit no bucket)
#   3. A tela final mostra o par S3 pronto: Access Key ID e Secret Access Key.
#      Eles são DERIVADOS do token: access key = ID do token e
#      secret = SHA-256 do valor do token — guarde o valor bruto (cfat_...)
#      em CLOUDFLARE_R2_API_TOKEN para poder re-derivar após rotação.
#
# ROTAÇÃO: ao rolar o token, o valor muda → secret novo = SHA-256 do valor
# novo (access key permanece, é o ID do token).
#
# Referência apenas — o código NÃO lê esta variável:
CLOUDFLARE_R2_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
# Default: https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_REGION=auto

# ===== Cloudflare D1 (banco via REST API) =====
# Opcional: vazio = SQLite local (default). "d1" ativa o banco remoto.
# ATENÇÃO: só ligue com as três variáveis abaixo preenchidas — o boot falha
# de propósito se o driver estiver ligado sem credenciais.
# Primeira ativação: siga plans/07-d1-activation.md (db-init + migrations).
TUDUDI_DB_DRIVER=
#
# COMO OBTER:
#   Database → Painel → Storage & Databases → D1 → Create database
#   (ou: npx wrangler d1 create <nome>); copie o UUID:
CLOUDFLARE_D1_DATABASE_ID=
#
#   Token → precisa ser USER API Token (prefixo cfut_), criado em
#   My Profile → API Tokens → Create Token → Custom token:
#     - Permissão: Account / D1 / Read + Edit (Edit é obrigatório; Read junto)
#     - Account Resources: sua conta
#   Account Owned Tokens (cfat_, seção "Account API Tokens") NÃO funcionam
#   na API do D1 — retornam 401 genérico.
CLOUDFLARE_API_TOKEN=

# ===== Opcionais avançados =====
# Timeout por request ao D1 (ms, default 30000):
#CLOUDFLARE_D1_TIMEOUT_MS=
# Orçamento local de rate limit (default 1100 req/5min; limite CF: 1200):
#CLOUDFLARE_D1_MAX_REQUESTS_PER_WINDOW=
# Loga cada SQL nas migrations (diagnóstico):
#SQL_DEBUG=1
